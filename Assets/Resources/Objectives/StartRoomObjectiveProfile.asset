  m_Script: {fileID: 11500000, guid: a72b2a9e4d7447f69c92a68b7d70f003, type: 3}
  m_Name: StartRoomObjectiveProfile
  m_EditorClassIdentifier: Assembly-CSharp::ObjectiveProfile
  _roomType: 0
  _title: "\u0421\u0442\u0430\u0440\u0442\u043E\u0432\u0430\u044F \u043A\u043E\u043C\u043D\u0430\u0442\u0430"
  _steps:
  - _text: "\u041f\u043e\u0434\u0432\u0438\u0433\u0430\u0442\u044c\u0441\u044f \u043d\u0430 {MoveKeys}"
    _description: "\u041d\u0430\u0436\u043c\u0438\u0442\u0435 {MoveKeys} \u0438 \u0441\u0434\u0435\u043b\u0430\u0439\u0442\u0435 \u043b\u044e\u0431\u043e\u0439 \u0448\u0430\u0433 \u043f\u043e \u0441\u0442\u0430\u0440\u0442\u043e\u0432\u043e\u0439 \u043a\u043e\u043c\u043d\u0430\u0442\u0435."
    _trigger: 0
    _targetId: 
  - _text: "\u0423\u0434\u0430\u0440\u0438\u0442\u044c \u043d\u0430 {AttackKey}"
    _description: "\u041d\u0430\u0436\u043c\u0438\u0442\u0435 {AttackKey}, \u0447\u0442\u043e\u0431\u044b \u0432\u044b\u043f\u043e\u043b\u043d\u0438\u0442\u044c \u043e\u0431\u044b\u0447\u043d\u0443\u044e \u0430\u0442\u0430\u043a\u0443."
    _trigger: 1
    _targetId: 
  - _text: "\u0420\u0430\u0437\u0431\u0438\u0442\u044c \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u0431\u0430\u043a \u043d\u0430 {AttackKey}"
    _description: "\u041d\u0430\u0439\u0434\u0438\u0442\u0435 \u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u0431\u0430\u043a \u0432 \u0441\u0442\u0430\u0440\u0442\u043e\u0432\u043e\u0439 \u043a\u043e\u043c\u043d\u0430\u0442\u0435 \u0438 \u0431\u0435\u0439\u0442\u0435 \u0435\u0433\u043e \u043d\u0430 {AttackKey}, \u043f\u043e\u043a\u0430 \u043e\u043d \u043d\u0435 \u0441\u043b\u043e\u043c\u0430\u0435\u0442\u0441\u044f."
    _trigger: 2
    _targetId: start.large_tank
  - _text: "\u0420\u0430\u0437\u0431\u0438\u0442\u044c \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0439 \u0431\u0430\u043a \u043d\u0430 {AttackKey}"
    _description: "\u041d\u0430\u0439\u0434\u0438\u0442\u0435 \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0438\u0439 \u0431\u0430\u043a \u0441 \u0440\u0435\u0441\u0443\u0440\u0441\u0430\u043c\u0438 \u0438 \u0440\u0430\u0437\u0431\u0435\u0439\u0442\u0435 \u0435\u0433\u043e \u0430\u0442\u0430\u043a\u043e\u0439 \u043d\u0430 {AttackKey}."
    _trigger: 2
    _targetId: start.small_tank
  - _text: "\u0421\u044a\u0435\u0441\u0442\u044c \u0431\u0430\u0442\u0430\u0440\u0435\u0439\u043a\u0443 \u043d\u0430 {UseItemKey}"
    _description: "\u041d\u0430\u0439\u0434\u0438\u0442\u0435 \u0431\u0430\u0442\u0430\u0440\u0435\u0439\u043a\u0443, \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0435\u0451 \u0432 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u043c \u0441\u043b\u043e\u0442\u0435 \u0438 \u043d\u0430\u0436\u043c\u0438\u0442\u0435 {UseItemKey}, \u0447\u0442\u043e\u0431\u044b \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c."
    _trigger: 3
    _targetId: 
  - _text: "\u041a\u0443\u043f\u0438\u0442\u044c \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0435 \u0432 \u0442\u0435\u0440\u043c\u0438\u043d\u0430\u043b\u0435"
    _description: "\u041f\u043e\u0434\u043e\u0439\u0434\u0438\u0442\u0435 \u043a \u0442\u0435\u0440\u043c\u0438\u043d\u0430\u043b\u0443, \u043d\u0430\u0436\u043c\u0438\u0442\u0435 {InteractKey} \u0438 \u043a\u0443\u043f\u0438\u0442\u0435 \u043b\u044e\u0431\u043e\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0435 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u0435."
    _trigger: 5
    _targetId: start.terminal
  - _text: "\u041f\u0435\u0440\u0435\u0439\u0442\u0438 \u0432 \u0434\u0440\u0443\u0433\u0443\u044e \u043a\u043e\u043c\u043d\u0430\u0442\u0443"
    _description: "\u0414\u043e\u0439\u0434\u0438\u0442\u0435 \u0434\u043e \u0432\u044b\u0445\u043e\u0434\u0430 \u0438 \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0435\u0440\u044c \u0432 \u0434\u0440\u0443\u0433\u0443\u044e \u043a\u043e\u043c\u043d\u0430\u0442\u0443."
    _trigger: 4
    _targetId: 
